{
  "name": "trakko",
  "productName": "Trakko",
  "version": "1.0.1",
  "description": "A cross-platform personal project board with Kanban task management",
  "main": ".webpack/main",
  "private": true,
  "scripts": {
    "prestart": "node -e \"const fs=require('fs'),p=require('path'),d=p.join(require.resolve('electron'),'..','dist','Electron.app','Contents','Info.plist');if(fs.existsSync(d)){let s=fs.readFileSync(d,'utf8');if(s.includes('>Electron<')){s=s.replace(/>Electron</g,'>Trakko<');fs.writeFileSync(d,s);console.log('Patched Electron.app name to Trakko')}}\"",
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "lint": "eslint --ext .ts,.tsx .",
    "rebuild": "electron-rebuild -f -w better-sqlite3,node-pty",
    "dist": "npm run rebuild && npm run make"
  },
  "keywords": [],
  "author": {
    "name": "victortrinh",
    "email": "31662661+victortrinh@users.noreply.github.com"
  },
  "license": "MIT",
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron-forge/plugin-webpack": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "@vercel/webpack-asset-relocator-loader": "^1.7.3",
    "css-loader": "^6.11.0",
    "electron": "41.0.3",
    "eslint": "^8.57.1",
    "eslint-plugin-import": "^2.32.0",
    "fork-ts-checker-webpack-plugin": "^7.3.0",
    "node-loader": "^2.1.0",
    "postcss": "^8.5.8",
    "postcss-loader": "^8.2.1",
    "style-loader": "^3.3.4",
    "tailwindcss": "^4.2.1",
    "ts-loader": "^9.5.4",
    "typescript": "~5.4.0"
  },
  "dependencies": {
    "@dnd-kit/helpers": "^0.3.2",
    "@dnd-kit/react": "^0.3.2",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "better-sqlite3": "^12.8.0",
    "electron-squirrel-startup": "^1.0.1",
    "node-pty": "^1.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "zustand": "^5.0.12"
  }
}
